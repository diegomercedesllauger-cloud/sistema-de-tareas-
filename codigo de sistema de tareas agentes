class AgenteChatbot:
    """AGENTE 5: Chatbot - Responde preguntas sobre tareas"""
    
    def responder(self, pregunta: str, tareas: List[Tarea]) -> str:
        """
        Responde preguntas naturales sobre tareas
        
        Ejemplos:
        - "¿Cuántas tareas tengo?"
        - "¿Cuál vence primero?"
        - "¿Cuál es la más urgente?"
        """
        
        pregunta_lower = pregunta.lower()
        
        # Cuántas tareas
        if "cuántas" in pregunta_lower or "total" in pregunta_lower:
            total = len(tareas)
            pendientes = sum(1 for t in tareas if t.estado == "PENDIENTE")
            return f"Tienes {total} tareas en total, {pendientes} pendientes."
        
        # Cuál vence primero
        if "vence primero" in pregunta_lower or "próxima" in pregunta_lower:
            if tareas:
                proxima = min(tareas, key=lambda t: t.fecha_limite)
                dias = (proxima.fecha_limite - datetime.now()).days
                return f"La próxima es: '{proxima.titulo}' en {dias} días."
            return "No tienes tareas pendientes."
        
        # Cuál es más urgente
        if "urgente" in pregunta_lower or "crítica" in pregunta_lower:
            criticas = [t for t in tareas if t.urgencia == "CRÍTICA"]
            if criticas:
                return f"Tareas críticas: {', '.join([t.titulo for t in criticas])}"
            return "No tienes tareas críticas."
        
        # Tareas completadas
        if "completada" in pregunta_lower or "hecho" in pregunta_lower:
            completadas = sum(1 for t in tareas if t.estado == "COMPLETADA")
            return f"Has completado {completadas} tareas."
        
        # Respuesta por defecto
        return "No entiendo tu pregunta. Intenta: '¿Cuántas tareas tengo?', '¿Cuál vence primero?'"


