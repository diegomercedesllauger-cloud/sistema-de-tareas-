            self.bd.crear_recomendacion(rec)
        
        print("  ✓ Tarea guardada en BD")
        
        # Actualizar estadísticas
        self.bd.actualizar_estadisticas(self.estudiante.id_estudiante)
        
        print("\n" + "="*70)
        print(f"✓ TAREA CREADA EXITOSAMENTE (ID: {id_tarea})")
        print("="*70 + "\n")
        
        return tarea
    
    def generar_portada(self, id_tarea: int) -> Optional[str]:
        """Genera portada Markdown/PDF para una tarea"""
        
        # Obtener tarea
        tareas = self.bd.obtener_tareas(self.estudiante.id_estudiante)
        tarea = next((t for t in tareas if t.id_tarea == id_tarea), None)
        
        if not tarea:
            print(f"❌ Tarea {id_tarea} no encontrada")
            return None
        
        print("\n" + "="*70)
        print("[AGENTE 4] GENERADOR DE PORTADA")
        print("="*70)
        
        # Generar Markdown
        portada_md = self.generador.generar_portada_markdown(
            tarea,
            {
                "nombre": self.estudiante.nombre,
                "matricula": self.estudiante.matricula,
                "carrera": self.estudiante.carrera,
                "profesor": "Por especificar"
            }
        )
        
        # Guardar Markdown
        nombre_archivo = tarea.titulo.replace(" ", "_").lower()[:50]
        archivo_md = f"portada_{nombre_archivo}.md"
        
        with open(archivo_md, 'w', encoding='utf-8') as f:
            f.write(portada_md)
        
        print(f"✓ Portada Markdown: {archivo_md}")
        
        # Intentar convertir a PDF
        try:
            import pypandoc
            archivo_pdf = f"portada_{nombre_archivo}.pdf"
            pypandoc.convert_file(archivo_md, 'pdf', outputfile=archivo_pdf)
            print(f"✓ Portada PDF: {archivo_pdf}")
            resultado = archivo_pdf
        except:
            print("⚠️  PDF requiere pandoc. Usa Markdown directamente.")
            resultado = archivo_md
        
        print("="*70 + "\n")
        return resultado
    
    def listar_tareas(self, filtro: str = None) -> List[Tarea]:
        """Lista tareas"""
