"""
📊 MODELOS DE DATOS
Define la estructura de todas las entidades
"""

from dataclasses import dataclass
from datetime import datetime
from typing import List, Optional


@dataclass
class Estudiante:
    """Representa un estudiante"""
    id_estudiante: Optional[int] = None
    nombre: str = "Diego Mercedes Llauger"
    matricula: str = "2026-0048"
    carrera: str = "Ingeniería en Ciberseguridad"
    institucion: str = "Universidad Dominicano Americana"
    
    def to_dict(self):
        return {
            "id": self.id_estudiante,
            "nombre": self.nombre,
            "matricula": self.matricula,
            "carrera": self.carrera,
            "institucion": self.institucion
        }


@dataclass
class Asignatura:
    """Representa una asignatura/curso"""
    id_asignatura: Optional[int] = None
    nombre: str = ""
    profesor: str = ""
    codigo: str = ""
    
    def to_dict(self):
        return {
            "id": self.id_asignatura,
            "nombre": self.nombre,
            "profesor": self.profesor,
            "codigo": self.codigo
        }


@dataclass
class Tarea:
    """Representa una tarea académica"""
    id_tarea: Optional[int] = None
    id_estudiante: int = 1
    titulo: str = ""
    descripcion: str = ""
    fecha_creacion: datetime = None
    fecha_limite: datetime = None
    prioridad: str = "MEDIA"  # ALTA, MEDIA, BAJA
    estado: str = "PENDIENTE"  # PENDIENTE, EN_PROGRESO, COMPLETADA
    urgencia: str = "MEDIA"  # CRÍTICA, ALTA, MEDIA, BAJA, VENCIDA
    id_asignatura: Optional[int] = None
    dias_para_vencer: int = 0
    tags: List[str] = None
    
    def __post_init__(self):
        if self.fecha_creacion is None:
            self.fecha_creacion = datetime.now()
        if self.tags is None:
            self.tags = []
    
    def to_dict(self):
        return {
            "id": self.id_tarea,
            "titulo": self.titulo,
            "descripcion": self.descripcion,
            "fecha_limite": self.fecha_limite.isoformat() if self.fecha_limite else None,
            "prioridad": self.prioridad,
            "estado": self.estado,
            "urgencia": self.urgencia,
            "dias_para_vencer": self.dias_para_vencer,
            "tags": self.tags
        }


@dataclass
class Recomendacion:
    """Representa una recomendación para mejorar tarea"""
    id_recomendacion: Optional[int] = None
    id_tarea: int = None
    tipo: str = ""  # ACADÉMICA, PROCESO, MEJORA_TIEMPO
    contenido: str = ""
    fecha_creacion: datetime = None
    
    def __post_init__(self):
        if self.fecha_creacion is None:
            self.fecha_creacion = datetime.now()
    
    def to_dict(self):
        return {
            "id": self.id_recomendacion,
            "id_tarea": self.id_tarea,
            "tipo": self.tipo,
            "contenido": self.contenido
        }


@dataclass
class Estadistica:
    """Representa estadísticas de rendimiento"""
    id_estadistica: Optional[int] = None
    id_estudiante: int = None
    fecha_periodo: str = ""  # "2026-04" (año-mes)
    completadas: int = 0
    vencidas: int = 0
    en_progreso: int = 0
    promedio_dias_para_entregar: float = 0.0
    tasa_exito: float = 0.0  # porcentaje
    
    def to_dict(self):
        return {
            "id": self.id_estadistica,
            "completadas": self.completadas,
            "vencidas": self.vencidas,
            "promedio_dias": self.promedio_dias_para_entregar,
            "tasa_exito": self.tasa_exito
        }

