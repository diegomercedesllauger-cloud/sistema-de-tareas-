class AgenteAprendizaje:
    """AGENTE 7: Aprendizaje de Datos - Analiza patrones"""
    
    def analizar(self, tareas: List[Tarea]) -> Dict:
        """
        Analiza datos y genera insights
        Devuelve: {
            "tareas_totales": int,
            "completadas": int,
            "vencidas": int,
            "tasa_exito": float,
            "promedio_dias": float,
            "patrones": List[str]
        }
        """
        
        if not tareas:
            return {
                "tareas_totales": 0,
                "completadas": 0,
                "vencidas": 0,
                "tasa_exito": 0,
                "promedio_dias": 0,
                "patrones": ["Crea tu primera tarea"]
            }
        
        # Cálculos básicos
        totales = len(tareas)
        completadas = sum(1 for t in tareas if t.estado == "COMPLETADA")
        vencidas = sum(1 for t in tareas if t.urgencia == "VENCIDA")
        tasa_exito = (completadas / totales * 100) if totales > 0 else 0
        
        # Promedio de días
        dias_totales = sum(max(0, t.dias_para_vencer) for t in tareas)
        promedio_dias = dias_totales / totales if totales > 0 else 0
        
        # Detectar patrones
        patrones = []
        
        # Patrón 1: Tareas por prioridad
        altas = sum(1 for t in tareas if t.prioridad == "ALTA")
        if altas > totales * 0.5:
            patrones.append(f"⚠️ {altas}/{totales} tareas son de prioridad ALTA. Considera ser más selectivo.")
        
        # Patrón 2: Tareas completadas
        if tasa_exito > 80:
            patrones.append("✓ Excelente tasa de éxito. Estás entregando a tiempo.")
        elif tasa_exito < 40:
            patrones.append("🔴 Baja tasa de éxito. Revisa tu planificación.")
        
        # Patrón 3: Vencidas
        if vencidas > 0:
            patrones.append(f"📌 Tienes {vencidas} tareas vencidas. Prioriza completarlas.")
        
        # Patrón 4: Promedio de tiempo
        if promedio_dias < 3:
            patrones.append("⏱️ Tiendes a dejar las tareas para último momento. Empieza más temprano.")
        elif promedio_dias > 10:
            patrones.append("✓ Buen margen de tiempo. Distribuye el trabajo uniformemente.")
        
        return {
            "tareas_totales": totales,
            "completadas": completadas,
            "vencidas": vencidas,
            "tasa_exito": round(tasa_exito, 1),
            "promedio_dias": round(promedio_dias, 1),
            "patrones": patrones
        }


