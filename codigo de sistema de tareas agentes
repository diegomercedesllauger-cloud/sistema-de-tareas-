        valida, errores = self.validador.validar(tarea)
        
        if not valida:
            print("  ❌ Errores encontrados:")
            for error in errores:
                print(f"     - {error}")
            return None
        print("  ✓ Tarea válida")
        
        # PASO 3: Asignador
        print("\n[AGENTE 3/7] ASIGNADOR → Calculando metadatos...")
        tarea = self.asignador.asignar(tarea)
        print(f"  ✓ Urgencia: {tarea.urgencia}")
        print(f"  ✓ Días para vencer: {tarea.dias_para_vencer}")
        
        # PASO 4: Generador (solo info, no genera archivo aún)
        print("\n[AGENTE 4/7] GENERADOR → Portada lista para generar")
        print("  ℹ️  Usa generar_portada(id_tarea) para crear archivo")
        
