import re
from datetime import datetime, timedelta
from typing import Dict, List, Optional, Tuple
from modelos import Tarea, Recomendacion, Estadistica


class AgenteParseador:
    """AGENTE 1: Parseador - Convierte texto a estructura"""
    
    def __init__(self):
        self.meses = {
            "enero": 1, "febrero": 2, "marzo": 3, "abril": 4,
            "mayo": 5, "junio": 6, "julio": 7, "agosto": 8,
            "septiembre": 9, "octubre": 10, "noviembre": 11, "diciembre": 12
        }
    
    def parsear(self, texto_usuario: str) -> Dict:
        """
        Convierte: "Trabajo urgente para el 25 de mayo"
        En: {titulo, fecha_limite, prioridad, ...}
        """
        
        titulo = self._extraer_titulo(texto_usuario)
        fecha = self._extraer_fecha(texto_usuario)
        prioridad = self._extraer_prioridad(texto_usuario)
        asignatura = self._extraer_asignatura(texto_usuario)
        tags = self._extraer_tags(texto_usuario)
        
        return {
            "titulo": titulo,
            "descripcion": "",
            "fecha_limite": fecha,
            "prioridad": prioridad,
            "asignatura": asignatura,
            "tags": tags
        }
    
    def _extraer_titulo(self, texto: str) -> str:
        """Extrae título (primeras palabras)"""
        palabras = texto.split()[:8]
        titulo = " ".join(palabras)
        # Limpiar palabras como "para el", "en", "el"
        titulo = re.sub(r'\b(para|el|la|en|de|por)\b', '', titulo, flags=re.IGNORECASE).strip()
        return titulo[:80]  # Máximo 80 caracteres
    
    def _extraer_fecha(self, texto: str) -> datetime:
        """Extrae fecha: '25 de mayo' → datetime"""
        
        # Búsqueda de patrón "DD de mes"
        match = re.search(r'(\d{1,2})\s+de\s+(\w+)', texto, re.IGNORECASE)
        
        if match:
            dia = int(match.group(1))
            mes_str = match.group(2).lower()
            mes = self.meses.get(mes_str, datetime.now().month)
            año = datetime.now().year
            
            try:
                return datetime(año, mes, dia)
            except ValueError:
                return datetime.now() + timedelta(days=7)
        
        # Búsqueda de palabras clave
        if "mañana" in texto.lower():
            return datetime.now() + timedelta(days=1)
        elif "próxima semana" in texto.lower():
            return datetime.now() + timedelta(days=7)
        elif "en 3 días" in texto.lower():
            return datetime.now() + timedelta(days=3)
        else:
            return datetime.now() + timedelta(days=7)  # Por defecto: próxima semana
    
    def _extraer_prioridad(self, texto: str) -> str:
        """Detecta prioridad: urgente → ALTA"""
        texto_lower = texto.lower()
        
        if any(word in texto_lower for word in ["urgente", "crítico", "importante", "hoy"]):
            return "ALTA"
        elif any(word in texto_lower for word in ["cuando pueda", "sin prisa", "baja"]):
            return "BAJA"
        else:
            return "MEDIA"
    
    def _extraer_asignatura(self, texto: str) -> Optional[str]:
        """Detecta asignatura mencionada"""
        asignaturas = [
            "ciberseguridad", "programación", "redes", "bases datos",
            "seguridad", "python", "javascript", "análisis"
        ]
        
        for asig in asignaturas:
            if asig in texto.lower():
                return asig.title()
        return None
    
    def _extraer_tags(self, texto: str) -> List[str]:
        """Extrae tags con formato #tag"""
        return re.findall(r'#(\w+)', texto)


class AgenteValidador:
    """AGENTE 2: Validador - Verifica datos completos"""
    
    def validar(self, tarea: Tarea) -> Tuple[bool, List[str]]:
        """
        Valida que tarea tenga campos obligatorios
        Devuelve: (es_válida, lista_de_errores)
        """
        
        errores = []
        
        # Validar título
        if not tarea.titulo or len(tarea.titulo) < 3:
            errores.append("Título muy corto (mínimo 3 caracteres)")
        
        # Validar fecha
        if not tarea.fecha_limite:
            errores.append("Falta fecha límite")
        elif tarea.fecha_limite < datetime.now():
            errores.append("Fecha límite está en el pasado")
        
        # Validar prioridad
        if tarea.prioridad not in ["ALTA", "MEDIA", "BAJA"]:
            errores.append(f"Prioridad inválida: {tarea.prioridad}")
        
        return len(errores) == 0, errores


