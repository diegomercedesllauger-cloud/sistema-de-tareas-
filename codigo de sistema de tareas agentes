        frame_botones = ttk.Frame(self.root, padding="10")
        frame_botones.pack(fill=tk.X, padx=10, pady=5)
        
        ttk.Button(frame_botones, text="📄 Generar Portada", command=self._generar_portada).pack(side=tk.LEFT, padx=5)
        ttk.Button(frame_botones, text="✏️ Editar", command=self._editar_tarea).pack(side=tk.LEFT, padx=5)
        ttk.Button(frame_botones, text="💡 Recomendaciones", command=self._mostrar_recomendaciones).pack(side=tk.LEFT, padx=5)
        ttk.Button(frame_botones, text="🗑️ Eliminar", command=self._eliminar_tarea).pack(side=tk.LEFT, padx=5)
        ttk.Button(frame_botones, text="🔄 Actualizar", command=self._actualizar_tareas).pack(side=tk.LEFT, padx=5)
    
    def _actualizar_tareas(self):
        """Actualiza tabla de tareas"""
        
        # Limpiar tabla
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        # Obtener tareas
        filtro = self.entrada_busqueda.get()
        tareas = self.gestor.listar_tareas(filtro if filtro else None)
        
        # Colores por urgencia
        colores = {
            "VENCIDA": "red",
            "CRÍTICA": "orange",
            "ALTA": "yellow",
            "MEDIA": "blue",
            "BAJA": "green"
        }
        
        # Agregar tareas a tabla
        for tarea in tareas:
            color = colores.get(tarea.urgencia, "black")
            
            self.tree.insert(
                "",
                "end",
                values=(
                    tarea.id_tarea,
                    tarea.titulo[:50],
                    tarea.fecha_limite.strftime("%d/%m/%Y"),
                    tarea.urgencia,
                    tarea.estado
                ),
                tags=(color,)
            )
        
        # Configurar colores
        self.tree.tag_configure("red", foreground="red")
        self.tree.tag_configure("orange", foreground="orange")
        self.tree.tag_configure("yellow", foreground="goldenrod")
        self.tree.tag_configure("blue", foreground="blue")
        self.tree.tag_configure("green", foreground="green")
    
    def _nueva_tarea(self):
        """Crea nueva tarea"""
        
        # Dialog simple
        dialog = tk.Toplevel(self.root)
        dialog.title("➕ Nueva Tarea")
        dialog.geometry("600x400")
        
        # Entrada de texto
        ttk.Label(dialog, text="Describe tu tarea:").pack(padx=10, pady=10)
        
        texto = scrolledtext.ScrolledText(dialog, height=10, width=70)
        texto.pack(padx=10, pady=5, fill=tk.BOTH, expand=True)
        
        def crear():
            contenido = texto.get("1.0", tk.END).strip()
            if contenido:
                tarea = self.gestor.crear_tarea_desde_texto(contenido)
                if tarea:
                    messagebox.showinfo("✓ Éxito", f"Tarea creada: {tarea.titulo}")
                    self._actualizar_tareas()
                    dialog.destroy()
            else:
                messagebox.showerror("❌ Error", "Escribe una descripción")
        
        ttk.Button(dialog, text="✓ Crear Tarea", command=crear).pack(padx=10, pady=10)
    
    def _generar_portada(self):
        """Genera portada para tarea seleccionada"""
        
        seleccion = self.tree.selection()
        if not seleccion:
            messagebox.showwarning("⚠️ Aviso", "Selecciona una tarea")
            return
        
        item = self.tree.item(seleccion[0])
        id_tarea = item['values'][0]
        
        archivo = self.gestor.generar_portada(id_tarea)
        if archivo:
            messagebox.showinfo("✓ Portada Generada", f"Archivo: {archivo}")
    
    def _abrir_tarea(self, event):
        """Abre detalles de tarea"""
        seleccion = self.tree.selection()
        if not seleccion:
            return
        
        item = self.tree.item(seleccion[0])
        id_tarea = item['values'][0]
        
        tareas = self.gestor.listar_tareas()
        tarea = next((t for t in tareas if t.id_tarea == id_tarea), None)
        
        if tarea:
            ventana = tk.Toplevel(self.root)
            ventana.title(f"📝 {tarea.titulo}")
            ventana.geometry("600x500")
            
            # Información
            info = f"""
            ID: {tarea.id_tarea}
            Título: {tarea.titulo}
            Fecha Límite: {tarea.fecha_limite.strftime('%d/%m/%Y')}
            Prioridad: {tarea.prioridad}
            Urgencia: {tarea.urgencia}
            Estado: {tarea.estado}
            Días para vencer: {tarea.dias_para_vencer}
            
            Descripción:
            {tarea.descripcion or 'Sin descripción'}
            """
            
            texto = scrolledtext.ScrolledText(ventana, height=20, width=70)
            texto.pack(padx=10, pady=10, fill=tk.BOTH, expand=True)
            texto.insert(tk.END, info)
            texto.config(state=tk.DISABLED)
    
    def _mostrar_recomendaciones(self):
        """Muestra recomendaciones de tarea"""
        
        seleccion = self.tree.selection()
        if not seleccion:
            messagebox.showwarning("⚠️ Aviso", "Selecciona una tarea")
            return
        
        item = self.tree.item(seleccion[0])
        id_tarea = item['values'][0]
        
        recomendaciones = self.gestor.obtener_recomendaciones(id_tarea)
        
        if recomendaciones:
            texto = "💡 RECOMENDACIONES:\n\n"
            for i, rec in enumerate(recomendaciones, 1):
                texto += f"{i}. [{rec.tipo}]\n{rec.contenido}\n\n"
        else:
            texto = "Sin recomendaciones específicas"
        
        messagebox.showinfo("💡 Recomendaciones", texto)
    
    def _mostrar_estadisticas(self):
        """Muestra estadísticas"""
        
        tareas = self.gestor.listar_tareas()
        insights = self.gestor.aprendizaje.analizar(tareas)
        
        texto = f"""
        📊 ESTADÍSTICAS
        
        Total de tareas: {insights['tareas_totales']}
        Completadas: {insights['completadas']}
        Vencidas: {insights['vencidas']}
        Tasa de éxito: {insights['tasa_exito']}%
        Promedio días: {insights['promedio_dias']}
        """
        
        messagebox.showinfo("📊 Estadísticas", texto)
    
    def _mostrar_patrones(self):
        """Muestra patrones detectados"""
        
        tareas = self.gestor.listar_tareas()
        insights = self.gestor.aprendizaje.analizar(tareas)
        
        texto = "📈 PATRONES DETECTADOS:\n\n"
        for patron in insights['patrones']:
            texto += f"• {patron}\n"
        
        messagebox.showinfo("📈 Patrones", texto)
    
    def _abrir_chat(self):
        """Abre ventana de chat"""
        
        chat_window = tk.Toplevel(self.root)
        chat_window.title("💬 Chat Inteligente")
        chat_window.geometry("600x400")
        
        # Historial
        historial = scrolledtext.ScrolledText(chat_window, height=15, width=70, state=tk.DISABLED)
        historial.pack(padx=10, pady=10, fill=tk.BOTH, expand=True)
        
        # Entrada
        entrada = ttk.Entry(chat_window)
        entrada.pack(padx=10, pady=5, fill=tk.X)
        
        def enviar():
            pregunta = entrada.get()
            if pregunta:
                respuesta = self.gestor.chat(pregunta)
                
                historial.config(state=tk.NORMAL)
                historial.insert(tk.END, f"Tú: {pregunta}\n")
                historial.insert(tk.END, f"Bot: {respuesta}\n\n")
                historial.config(state=tk.DISABLED)
                
                entrada.delete(0, tk.END)
        
        ttk.Button(chat_window, text="Enviar", command=enviar).pack(padx=10, pady=5)
        entrada.bind("<Return>", lambda e: enviar())
    
    def _editar_tarea(self):
        """Edita tarea seleccionada"""
        messagebox.showinfo("ℹ️ Función", "Doble clic en tarea para ver detalles")
    
    def _eliminar_tarea(self):
        """Elimina tarea seleccionada"""
        
        seleccion = self.tree.selection()
        if not seleccion:
            messagebox.showwarning("⚠️ Aviso", "Selecciona una tarea")
            return
        
        if messagebox.askyesno("Confirmar", "¿Eliminar esta tarea?"):
            item = self.tree.item(seleccion[0])
            id_tarea = item['values'][0]
            
            self.gestor.bd.eliminar_tarea(id_tarea)
            self._actualizar_tareas()
            messagebox.showinfo("✓ Éxito", "Tarea eliminada")


