"""
💾 BASE DE DATOS SQLite
Maneja todas las operaciones de la BD
"""

import sqlite3
from typing import List, Dict, Optional
from datetime import datetime
from modelos import Estudiante, Asignatura, Tarea, Recomendacion, Estadistica


class BaseDatos:
    """Gestor de base de datos SQLite"""
    
    def __init__(self, archivo: str = "tareas_diego.db"):
        self.archivo = archivo
        self.conexion = None
        self.inicializar()
    
    def conectar(self):
        """Conecta a la BD"""
        self.conexion = sqlite3.connect(self.archivo)
        self.conexion.row_factory = sqlite3.Row
        return self.conexion
    
    def desconectar(self):
        """Cierra conexión"""
        if self.conexion:
            self.conexion.close()
    
    def inicializar(self):
        """Crea tablas si no existen"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        # Tabla: Estudiantes
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS estudiantes (
                id_estudiante INTEGER PRIMARY KEY AUTOINCREMENT,
                nombre TEXT NOT NULL,
                matricula TEXT UNIQUE NOT NULL,
                carrera TEXT NOT NULL,
                institucion TEXT NOT NULL,
                fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        
        # Tabla: Asignaturas
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS asignaturas (
                id_asignatura INTEGER PRIMARY KEY AUTOINCREMENT,
                nombre TEXT NOT NULL UNIQUE,
                profesor TEXT,
                codigo TEXT UNIQUE,
                fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        
        # Tabla: Tareas
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS tareas (
                id_tarea INTEGER PRIMARY KEY AUTOINCREMENT,
                id_estudiante INTEGER NOT NULL,
                titulo TEXT NOT NULL,
                descripcion TEXT,
                fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                fecha_limite TIMESTAMP,
                prioridad TEXT DEFAULT 'MEDIA',
                estado TEXT DEFAULT 'PENDIENTE',
                urgencia TEXT DEFAULT 'MEDIA',
                id_asignatura INTEGER,
                dias_para_vencer INTEGER DEFAULT 0,
                tags TEXT,
                FOREIGN KEY (id_estudiante) REFERENCES estudiantes(id_estudiante),
                FOREIGN KEY (id_asignatura) REFERENCES asignaturas(id_asignatura)
            )
        """)
        
        # Tabla: Recomendaciones
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS recomendaciones (
                id_recomendacion INTEGER PRIMARY KEY AUTOINCREMENT,
                id_tarea INTEGER NOT NULL,
                tipo TEXT NOT NULL,
                contenido TEXT NOT NULL,
                fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (id_tarea) REFERENCES tareas(id_tarea)
            )
        """)
        
        # Tabla: Estadísticas
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS estadisticas (
                id_estadistica INTEGER PRIMARY KEY AUTOINCREMENT,
                id_estudiante INTEGER NOT NULL,
                fecha_periodo TEXT,
                completadas INTEGER DEFAULT 0,
                vencidas INTEGER DEFAULT 0,
                en_progreso INTEGER DEFAULT 0,
                promedio_dias_para_entregar REAL DEFAULT 0.0,
                tasa_exito REAL DEFAULT 0.0,
                fecha_calculo TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (id_estudiante) REFERENCES estudiantes(id_estudiante)
            )
        """)
        
        self.conexion.commit()
        print("✓ Base de datos inicializada")
        self.desconectar()
    
    # ==================== OPERACIONES ESTUDIANTE ====================
    
    def crear_estudiante(self, est: Estudiante) -> int:
        """Crea estudiante, devuelve ID"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        try:
            cursor.execute("""
                INSERT INTO estudiantes (nombre, matricula, carrera, institucion)
                VALUES (?, ?, ?, ?)
            """, (est.nombre, est.matricula, est.carrera, est.institucion))
            
            self.conexion.commit()
            est.id_estudiante = cursor.lastrowid
            print(f"✓ Estudiante creado: {est.nombre}")
            return est.id_estudiante
        except sqlite3.IntegrityError:
            print(f"⚠️  Estudiante ya existe: {est.matricula}")
            return self.obtener_estudiante_por_matricula(est.matricula).id_estudiante
        finally:
            self.desconectar()
    
    def obtener_estudiante_por_matricula(self, matricula: str) -> Optional[Estudiante]:
        """Obtiene estudiante por matrícula"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("SELECT * FROM estudiantes WHERE matricula = ?", (matricula,))
        row = cursor.fetchone()
        self.desconectar()
        
        if row:
            return Estudiante(
                id_estudiante=row['id_estudiante'],
                nombre=row['nombre'],
                matricula=row['matricula'],
                carrera=row['carrera'],
                institucion=row['institucion']
            )
        return None
    
    # ==================== OPERACIONES ASIGNATURA ====================
    
    def crear_asignatura(self, asig: Asignatura) -> int:
        """Crea asignatura"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        try:
            cursor.execute("""
                INSERT INTO asignaturas (nombre, profesor, codigo)
                VALUES (?, ?, ?)
            """, (asig.nombre, asig.profesor, asig.codigo))
            
            self.conexion.commit()
            asig.id_asignatura = cursor.lastrowid
            return asig.id_asignatura
        except sqlite3.IntegrityError:
            print(f"⚠️  Asignatura ya existe: {asig.nombre}")
            return self.obtener_asignatura_por_nombre(asig.nombre).id_asignatura
        finally:
            self.desconectar()
    
    def obtener_asignatura_por_nombre(self, nombre: str) -> Optional[Asignatura]:
        """Obtiene asignatura por nombre"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("SELECT * FROM asignaturas WHERE nombre = ?", (nombre,))
        row = cursor.fetchone()
        self.desconectar()
        
        if row:
            return Asignatura(
                id_asignatura=row['id_asignatura'],
                nombre=row['nombre'],
                profesor=row['profesor'],
                codigo=row['codigo']
            )
        return None
    
    def listar_asignaturas(self) -> List[Asignatura]:
        """Lista todas las asignaturas"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("SELECT * FROM asignaturas")
        rows = cursor.fetchall()
        self.desconectar()
        
        return [
            Asignatura(
                id_asignatura=row['id_asignatura'],
                nombre=row['nombre'],
                profesor=row['profesor'],
                codigo=row['codigo']
            )
            for row in rows
        ]
    
    # ==================== OPERACIONES TAREA ====================
    
    def crear_tarea(self, tarea: Tarea) -> int:
        """Crea tarea"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("""
            INSERT INTO tareas 
            (id_estudiante, titulo, descripcion, fecha_limite, prioridad, 
             estado, urgencia, id_asignatura, dias_para_vencer, tags)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            tarea.id_estudiante,
            tarea.titulo,
            tarea.descripcion,
            tarea.fecha_limite.isoformat() if tarea.fecha_limite else None,
            tarea.prioridad,
            tarea.estado,
            tarea.urgencia,
            tarea.id_asignatura,
            tarea.dias_para_vencer,
            ",".join(tarea.tags) if tarea.tags else ""
        ))
        
        self.conexion.commit()
        tarea.id_tarea = cursor.lastrowid
        self.desconectar()
        
        print(f"✓ Tarea creada: {tarea.titulo}")
        return tarea.id_tarea
    
    def obtener_tareas(self, id_estudiante: int) -> List[Tarea]:
        """Obtiene todas las tareas de un estudiante"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute(
            "SELECT * FROM tareas WHERE id_estudiante = ? ORDER BY fecha_limite",
            (id_estudiante,)
        )
        rows = cursor.fetchall()
        self.desconectar()
        
        tareas = []
        for row in rows:
            tarea = Tarea(
                id_tarea=row['id_tarea'],
                id_estudiante=row['id_estudiante'],
                titulo=row['titulo'],
                descripcion=row['descripcion'],
                fecha_creacion=datetime.fromisoformat(row['fecha_creacion']),
                fecha_limite=datetime.fromisoformat(row['fecha_limite']) if row['fecha_limite'] else None,
                prioridad=row['prioridad'],
                estado=row['estado'],
                urgencia=row['urgencia'],
                id_asignatura=row['id_asignatura'],
                dias_para_vencer=row['dias_para_vencer'],
                tags=row['tags'].split(",") if row['tags'] else []
            )
            tareas.append(tarea)
        
        return tareas
    
    def actualizar_tarea(self, tarea: Tarea):
        """Actualiza una tarea"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("""
            UPDATE tareas SET
            titulo = ?, descripcion = ?, fecha_limite = ?,
            prioridad = ?, estado = ?, urgencia = ?,
            id_asignatura = ?, dias_para_vencer = ?, tags = ?
            WHERE id_tarea = ?
        """, (
            tarea.titulo,
            tarea.descripcion,
            tarea.fecha_limite.isoformat() if tarea.fecha_limite else None,
            tarea.prioridad,
            tarea.estado,
            tarea.urgencia,
            tarea.id_asignatura,
            tarea.dias_para_vencer,
            ",".join(tarea.tags) if tarea.tags else "",
            tarea.id_tarea
        ))
        
        self.conexion.commit()
        self.desconectar()
        print(f"✓ Tarea actualizada: {tarea.titulo}")
    
    def eliminar_tarea(self, id_tarea: int):
        """Elimina una tarea"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("DELETE FROM tareas WHERE id_tarea = ?", (id_tarea,))
        cursor.execute("DELETE FROM recomendaciones WHERE id_tarea = ?", (id_tarea,))
        
        self.conexion.commit()
        self.desconectar()
        print(f"✓ Tarea eliminada")
    
    # ==================== OPERACIONES RECOMENDACIÓN ====================
    
    def crear_recomendacion(self, rec: Recomendacion) -> int:
        """Crea una recomendación"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("""
            INSERT INTO recomendaciones (id_tarea, tipo, contenido)
            VALUES (?, ?, ?)
        """, (rec.id_tarea, rec.tipo, rec.contenido))
        
        self.conexion.commit()
        rec.id_recomendacion = cursor.lastrowid
        self.desconectar()
        
        return rec.id_recomendacion
    
    def obtener_recomendaciones(self, id_tarea: int) -> List[Recomendacion]:
        """Obtiene recomendaciones de una tarea"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute(
            "SELECT * FROM recomendaciones WHERE id_tarea = ?",
            (id_tarea,)
        )
        rows = cursor.fetchall()
        self.desconectar()
        
        return [
            Recomendacion(
                id_recomendacion=row['id_recomendacion'],
                id_tarea=row['id_tarea'],
                tipo=row['tipo'],
                contenido=row['contenido'],
                fecha_creacion=datetime.fromisoformat(row['fecha_creacion'])
            )
            for row in rows
        ]
    
    # ==================== OPERACIONES ESTADÍSTICA ====================
    
    def obtener_estadisticas(self, id_estudiante: int) -> Optional[Estadistica]:
        """Obtiene estadísticas del estudiante"""
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute(
            "SELECT * FROM estadisticas WHERE id_estudiante = ? ORDER BY fecha_calculo DESC LIMIT 1",
            (id_estudiante,)
        )
        row = cursor.fetchone()
        self.desconectar()
        
        if row:
            return Estadistica(
                id_estadistica=row['id_estadistica'],
                id_estudiante=row['id_estudiante'],
                fecha_periodo=row['fecha_periodo'],
                completadas=row['completadas'],
                vencidas=row['vencidas'],
                en_progreso=row['en_progreso'],
                promedio_dias_para_entregar=row['promedio_dias_para_entregar'],
                tasa_exito=row['tasa_exito']
            )
        return None
    
    def actualizar_estadisticas(self, id_estudiante: int):
        """Calcula y actualiza estadísticas"""
        tareas = self.obtener_tareas(id_estudiante)
        
        completadas = sum(1 for t in tareas if t.estado == "COMPLETADA")
        vencidas = sum(1 for t in tareas if t.urgencia == "VENCIDA")
        en_progreso = sum(1 for t in tareas if t.estado == "EN_PROGRESO")
        
        dias_promedio = sum(t.dias_para_vencer for t in tareas) / len(tareas) if tareas else 0
        tasa_exito = (completadas / len(tareas) * 100) if tareas else 0
        
        periodo = datetime.now().strftime("%Y-%m")
        
        self.conectar()
        cursor = self.conexion.cursor()
        
        cursor.execute("""
            INSERT INTO estadisticas 
            (id_estudiante, fecha_periodo, completadas, vencidas, 
             en_progreso, promedio_dias_para_entregar, tasa_exito)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        """, (id_estudiante, periodo, completadas, vencidas, en_progreso, dias_promedio, tasa_exito))
        
        self.conexion.commit()
        self.desconectar()


